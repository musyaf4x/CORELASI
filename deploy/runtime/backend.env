DEBUG=False
SECRET_KEY=replace-with-a-unique-random-secret-of-at-least-50-characters
ALLOWED_HOSTS=corelasi.example.local
CORS_ALLOWED_ORIGINS=https://corelasi.example.local
CSRF_TRUSTED_ORIGINS=https://corelasi.example.local
CORS_ALLOW_CREDENTIALS=True
AUTH_REFRESH_COOKIE_NAME=corelasi_refresh
AUTH_REFRESH_COOKIE_MAX_AGE=604800

TRUST_PROXY_HEADERS=True
SECURE_SSL_REDIRECT=True
SECURE_COOKIES=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

DB_ENGINE=postgresql
POSTGRES_DB=corelasi
POSTGRES_USER=corelasi_app
POSTGRES_PASSWORD=replace-with-a-unique-random-database-password
DB_HOST=127.0.0.1
DB_PORT=55432
DB_CONN_MAX_AGE=60
DB_CONNECT_TIMEOUT=5

DRF_NUM_PROXIES=1
THROTTLE_ANON_RATE=120/min
THROTTLE_USER_RATE=1200/min
THROTTLE_LOGIN_RATE=10/min
THROTTLE_TOKEN_REFRESH_RATE=30/min
THROTTLE_PASSWORD_RESET_RATE=3/hour
THROTTLE_UPLOAD_RATE=20/hour

MAX_UPLOAD_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
DATA_UPLOAD_MAX_MEMORY_SIZE=11534336
LOG_FILE=logs/corelasi.log

# Showcase Login Mode Settings
SHOWCASE_MODE=True
SHOWCASE_ACCOUNT_EMAILS=admin@corelasi.test,guru@corelasi.test,siswa@corelasi.test
